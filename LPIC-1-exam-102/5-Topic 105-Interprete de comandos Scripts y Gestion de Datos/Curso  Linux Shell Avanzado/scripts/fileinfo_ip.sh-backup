#!/bin/bash
# fileinfo.sh

FILES="/root/access_log /var/log/httpd/access_log" 

echo

for file in $FILES
do

  if [ ! -e "$file" ]       # Check if file exists.
  then
    echo "$file does not exist."
   
fi
     echo "Salida ordenada de los ficheros access_log NASA y Apache access_log"
      grep -Eo '^[a-z0-9]{1,8}\.[a-z0-9]{1,8}\.[a-z0-9]{1,8}\.[a-z0-8]{1,3}' $FILES |sort -n |uniq -c 
  
done  

exit 0
